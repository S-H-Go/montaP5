    "simplex-noise": "^4.0.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/p5": "^1.7.7",
    "eslint": "^10.1.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "[ \"$OS\" = \"Windows_NT\" ] && cmd.exe /c \"npm run lint-staged\" || npm run lint-staged"
